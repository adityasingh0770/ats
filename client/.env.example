# Production: set to your deployed API origin (no trailing slash, no /api suffix).
# Example: VITE_API_URL=https://mathmentor-api.onrender.com
# VITE_API_URL=

# Local dev only: if the API uses another port (e.g. PORT=5001 in server/.env), set:
# VITE_API_PROXY_TARGET=http://localhost:5001
# Optional dev server port (default 5173):
# VITE_DEV_PORT=5174
