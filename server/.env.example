PORT=8787
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d
NODE_ENV=production

# Optional: path to JSON file for users, learners, sessions (default: server/data/app-state.json).
# On hosts with ephemeral disk, set this to a persistent volume mount if you need durable data.
# DATA_FILE_PATH=

# Comma-separated frontend URLs (for CORS). Add your Vercel/Netlify URL here.
# Example: https://mathmentor.vercel.app
CLIENT_ORIGIN=

# Use Node 18+ on the host (see package.json engines). OpenAI calls use fetch or node-fetch fallback.
# LLM: OpenAI and/or Google Gemini (hints + remedial). Default LLM_PROVIDER=auto tries OpenAI first, then Gemini on 429/503.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# LLM_PROVIDER=auto
