PORT=8787
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d
NODE_ENV=production

# Optional: path to JSON file for users, learners, sessions (default: server/data/app-state.json).
# On hosts with ephemeral disk, set this to a persistent volume mount if you need durable data.
# DATA_FILE_PATH=

# Comma-separated frontend URLs (for CORS). Add your Vercel/Netlify URL here.
# Example: https://mathmentor.vercel.app
CLIENT_ORIGIN=

# Use Node 18+ on the host (see package.json engines).
# AI hints + remedial use Google Gemini only (Google AI Studio API key).
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Set to true to skip all Gemini calls (instant built-in hints + remedial; no 429s). Key can stay set.
# GEMINI_LLM_DISABLED=true
# Free tier = strict RPM limits. Default: no 429 retries (fast fallback to built-in hints). Optional: GEMINI_MAX_429_RETRIES=2
